    {
        "id": "537804877a99e447",
        "type": "function",
        "z": "3e1ec227d44610a8",
        "name": "Format Status",
        "func": "// Check if payload is a string and try to parse it if necessary\nlet data = msg.payload;\nif (typeof data === 'string') {\n    try {\n        data = JSON.parse(data); // Ensure data is a JSON object\n    } catch (e) {\n        // Fallback if it's just a raw string like \"RUNNING\"\n    }\n}\n\n// Extract state from the object or use raw payload\nlet s = (data && data.state) ? data.state : data;\n\n// Logic for Dashboard display\nif (s === 'RUNNING' || s === 'WASHING' || s === 'SPINNING' || s === 'STARTING') {\n    msg.payload = '🔴 RUNNING'; // Status active\n} else {\n    msg.payload = '🟢 IDLE';    // Status inactive/complete\n}\n\nreturn msg;",
