        "type": "function",
        "z": "3e1ec227d44610a8",
        "name": "Format Event",
        "func": "let data = msg.payload;\nif (typeof data === 'string') {\n    try {\n        data = JSON.parse(data);\n    } catch (e) {}\n}\n\n// Map properties with default fallbacks to avoid \"undefined\"\nlet eventName = (data && data.event) ? data.event : \"N/A\";\nlet eventTime = (data && data.time) ? data.time : new Date().toLocaleTimeString();\n\n// Format string for the UI text node\nmsg.payload = `Event: ${eventName}\\nTime: ${eventTime}`;\nreturn msg;",
